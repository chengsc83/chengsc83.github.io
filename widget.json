{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "items": [
        {
          "type": "TextBlock",
          "text": "${title}",
          "weight": "Bolder",
          "size": "ExtraLarge",
          "color": "Accent"
        },
        {
          "type": "TextBlock",
          "text": "${status}",
          "size": "Medium",
          "isSubtle": true
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "開啟辯時計",
      "data": {
        "action": "openApp"
      }
    }
  ]
}
